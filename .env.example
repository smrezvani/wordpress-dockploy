# Database Configuration
# Option 1: Use a DATABASE_URL (recommended for Dokploy)
DATABASE_URL=mysql://mysql:efw3zo2ivw98dpgf@cika-host-wpdb-zgtbn8:3306/mysql

# Option 2: Use individual variables (these override DATABASE_URL if set)
# DB_HOST=your-mysql-host:3306
# DB_USER=wordpress_user
# DB_PASSWORD=your_database_password_here
# DB_NAME=wordpress_production

# WordPress Configuration
TABLE_PREFIX=wp_
WP_DEBUG=false
WP_MEMORY_LIMIT=512M
WP_MAX_MEMORY_LIMIT=1024M
FORCE_SSL_ADMIN=true

# Performance Settings
WP_POST_REVISIONS=5
AUTOSAVE_INTERVAL=300
EMPTY_TRASH_DAYS=30

# PHP Configuration
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_VARS=5000